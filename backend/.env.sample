# Local dev sample environment variables
# Copy to .env and edit as needed before running services

# Postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/datalake

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Redis (used by orchestrator)
REDIS_URL=redis://redis:6379

# Gemini / external model key (leave empty for mock mode)
GEMINI_API_KEY=
